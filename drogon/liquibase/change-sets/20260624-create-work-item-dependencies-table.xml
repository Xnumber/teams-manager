    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
    http://www.liquibase.org/xml/ns/dbchangelog-ext
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd
    http://www.liquibase.org/xml/ns/secure
    http://www.liquibase.org/xml/ns/secure/liquibase-secure-latest.xsd">


	
    <changeSet author="clement" id="20260624-01-create-work-item-type-enum">
        <sql>
            CREATE TYPE work_item_type AS ENUM (
                'PROJECT',
                'MILESTONE',
                'TASK'
            );
        </sql>
        <rollback>
            DROP TYPE work_item_type;
        </rollback>
	</changeSet>
    <changeSet author="clement" id="20260624-01-create-work-item-dependency-type-enum">
        <sql>
            CREATE TYPE work_item_dependency_type AS ENUM (
                'FS',
                'SS',
                'FF',
                'SF'
            );
        </sql>
        <rollback>
            DROP TYPE work_item_dependency_type;
        </rollback>
	</changeSet>
    <changeSet id="20260624-02-create-work-items-table" author="clement">
        <createTable tableName="work_items">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>

            
            <column name="work_item_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            
            <column name="item_type" type="work_item_type">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="20260624-03-create-work-item-dependencies" author="clement">
        <createTable tableName="work_item_dependencies">
            <!-- id -->
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>


            <!-- predecessor -->
            <column name="predecessor_type" type="work_item_type">
                <constraints nullable="false"/>
            </column>
            <column name="predecessor_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="successor_type" type="work_item_type">
                <constraints nullable="false"/>
            </column>
            <column name="successor_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="dependency_type" type="work_item_dependency_type" defaultValue="FS">
                <constraints nullable="false"/>
            </column>
            <!-- created_at -->
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <!-- CHECK constraint -->

        <!-- ✅ CHECK constraint 用 SQL -->
        <sql>
            ALTER TABLE work_item_dependencies
            ADD CONSTRAINT chk_no_self_dependency
            CHECK (
                NOT (
                    predecessor_type = successor_type
                    AND predecessor_id = successor_id
                )
            );
        </sql>
    </changeSet>
